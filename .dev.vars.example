# Cloudflare Pages Functions - Local Development Environment Variables
# Copy this file to .dev.vars and populate with your API keys to run tests and host locally.

# Groq API Key
GROQ_API_KEY=

# Google AI Studio API Key (Gemini)
GOOGLE_API_KEY=

# NVIDIA NIM API Key
NVIDIA_API_KEY=

# OpenRouter API Key
OPENROUTER_API_KEY=

# Cloudflare API Token with "Account Analytics: Read" permission — used by
# /api/stats to query the Analytics Engine SQL API. Create at
# dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Cloudflare account id that owns the `prompt_optimizer_events` dataset
CLOUDFLARE_ACCOUNT_ID=

# Token required to view /api/stats (?token=... or X-Stats-Token header).
# If unset, /api/stats is public.
STATS_TOKEN=
